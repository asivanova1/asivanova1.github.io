<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ .Title }} | Анастасия Иванова</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #f5f7fa; font-family: 'Segoe UI', Arial, sans-serif; transition: all 0.3s ease; }
        body.dark { background: #1a1a2e; }
        
        .menu { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; padding: 20px; background: white; border-bottom: 1px solid #eaeaea; }
        body.dark .menu { background: #2a2a3e; border-bottom-color: #444; }
        .menu a { color: #4A90E2; text-decoration: none; font-weight: 500; }
        .menu a:hover { color: #357ABD; }
        
        .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
        
        .theme-switch { position: fixed; top: 20px; right: 20px; background: white; border: none; font-size: 24px; cursor: pointer; padding: 10px 15px; border-radius: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); z-index: 100; }
        body.dark .theme-switch { background: #2a2a3e; color: white; }
        
        .avatar { text-align: center; margin-bottom: 25px; }
        .avatar img { width: 140px; height: 140px; border-radius: 50%; object-fit: cover; border: 3px solid #4A90E2; }
        
        h1 { text-align: center; color: #1a1a2e; margin-bottom: 5px; }
        body.dark h1 { color: #eee; }
        
        .subtitle { text-align: center; color: #4A90E2; margin-top: 5px; margin-bottom: 30px; font-weight: 500; }
        
        .card { background: white; border-radius: 16px; padding: 30px; margin-bottom: 24px; border: 1px solid #eaeaea; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        body.dark .card { background: #2a2a3e; border-color: #444; }
        
        .card h1 { text-align: left; margin-bottom: 20px; border-left: 4px solid #4A90E2; padding-left: 20px; }
        
        h2 { color: #1a1a2e; margin: 25px 0 15px; font-size: 1.5em; border-left: 4px solid #4A90E2; padding-left: 15px; }
        body.dark h2 { color: #eee; }
        
        h3 { color: #1a1a2e; margin: 20px 0 12px; font-size: 1.3em; }
        body.dark h3 { color: #ddd; }
        
        p, li { color: #555; line-height: 1.6; }
        body.dark p, body.dark li { color: #ccc; }
        
        ul, ol { padding-left: 28px; margin: 15px 0; }
        li { margin: 8px 0; }
        
        a { color: #4A90E2; text-decoration: none; }
        a:hover { text-decoration: underline; }
        
        .footer { text-align: center; padding: 30px 0 20px; color: #888; font-size: 0.85em; border-top: 1px solid #eaeaea; margin-top: 40px; }
        body.dark .footer { border-top-color: #444; color: #666; }
    </style>
</head>
<body>

<div class="menu">
    <a href="/">Главная</a>
    <a href="/about/">Обо мне</a>
    <a href="/skills/">Навыки</a>
    <a href="/hobbies/">Хобби</a>
    <a href="/projects/">Проекты</a>
    <a href="/education/">Образование</a>
    <a href="/achievements/">Достижения</a>
    <a href="/post/">Посты</a>
</div>

<button class="theme-switch" onclick="toggleTheme()">🌓</button>

<div class="container">
    <div class="avatar">
        <img src="/avatar.png" alt="Анастасия Иванова">
    </div>
    
    <h1>Анастасия Иванова</h1>
    <div class="subtitle">Студентка РУДН | Математика и компьютерные науки (с 2025)</div>
    
    <div class="card">
        {{ .Content }}
    </div>
    
    <div class="footer">
        © 2026 Анастасия Иванова | Создано на Hugo
    </div>
</div>

<script>
    function toggleTheme() {
        document.body.classList.toggle('dark');
        localStorage.setItem('theme', document.body.classList.contains('dark') ? 'dark' : 'light');
    }
    if (localStorage.getItem('theme') === 'dark') {
        document.body.classList.add('dark');
    }
</script>
</body>
</html>
